{
  "name": "pdf-to-markdown",
  "version": "1.0.0",
  "description": "A TypeScript library to convert PDF to Markdown using a custom parser with SOLID principles",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./min": {
      "import": "./dist/index.min.js",
      "require": "./dist/index.min.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "build:tsc": "tsc",
    "build:esm": "tsc --project tsconfig.esm.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "generate-pdfs": "python scripts/generate-test-pdfs.py",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pdf",
    "markdown",
    "converter",
    "parser",
    "typescript",
    "pdf-to-markdown",
    "pdf-parser"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/pdf-to-markdown-js"
  },
  "bugs": {
    "url": "https://github.com/your-username/pdf-to-markdown-js/issues"
  },
  "homepage": "https://github.com/your-username/pdf-to-markdown-js#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "terser": "^5.46.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "buffer": "^6.0.3"
  }
}
